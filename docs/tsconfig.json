{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "PptxGenJS docs",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [".vitepress/**/*.ts", ".vitepress/**/*.mts"]
}
