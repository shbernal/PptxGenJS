{
	"name": "pptxgenjs",
	"version": "4.0.1",
	"author": {
		"name": "Brent Ely",
		"url": "https://github.com/gitbrent/"
	},
	"description": "Create JavaScript PowerPoint Presentations",
	"homepage": "https://gitbrent.github.io/PptxGenJS/",
	"license": "MIT",
	"packageManager": "pnpm@11.3.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"exports": {
		".": {
			"types": "./types/pptxgen.d.ts",
			"import": "./dist/pptxgen.js"
		}
	},
	"main": "dist/pptxgen.js",
	"module": "dist/pptxgen.js",
	"files": [
		"dist",
		"types"
	],
	"types": "types/pptxgen.d.ts",
	"scripts": {
		"build": "node scripts/build.mjs build",
		"build:dist": "node scripts/build.mjs dist",
		"start": "pnpm run watch",
		"watch": "rollup -cw",
		"test": "pnpm run build && vitest run test/regression.test.mjs && vitest run test/schema-validation.test.mjs",
		"test:unit": "pnpm run build && vitest run test/regression.test.mjs",
		"test:schema": "pnpm run build && vitest run test/schema-validation.test.mjs",
		"test:watch": "pnpm run build && vitest --watch test/regression.test.mjs",
		"test:coverage": "pnpm run build && vitest run --coverage test/regression.test.mjs",
		"test:package": "node scripts/package-smoke.mjs",
		"test:demo:node": "node scripts/demo-smoke.mjs node",
		"test:demo:vite": "node scripts/demo-smoke.mjs vite",
		"test:demos": "node scripts/demo-smoke.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"strict:check": "tsc -p tsconfig.strict.json --noEmit",
		"types:build": "node scripts/types.mjs",
		"lint": "eslint . --no-warn-ignored",
		"lint:fix": "pnpm run lint -- --fix",
		"format": "prettier package.json pnpm-workspace.yaml tsconfig*.json eslint.config.mjs rollup.config.mjs \"scripts/**/*.mjs\" \"test/**/*.mjs\" \"test/**/*.js\" \".github/**/*.yml\" --write",
		"format:check": "prettier package.json pnpm-workspace.yaml tsconfig*.json eslint.config.mjs rollup.config.mjs \"scripts/**/*.mjs\" \"test/**/*.mjs\" \"test/**/*.js\" \".github/**/*.yml\" --check",
		"prepack": "pnpm run build:dist && pnpm run types:build",
		"check-validator": "node tools/ooxml-validator/check-updates.js",
		"pack:check": "pnpm pack --dry-run --json"
	},
	"browser": {
		"express": false,
		"fs": false,
		"https": false,
		"node:fs": false,
		"node:https": false,
		"os": false,
		"path": false
	},
	"dependencies": {
		"jszip": "^3.10.1"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-typescript": "^12.3.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.9.2",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^10.4.1",
		"prettier": "^3.8.3",
		"rollup": "^4.61.1",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vitest": "^4.1.8"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gitbrent/PptxGenJS.git"
	},
	"keywords": [
		"es6-powerpoint",
		"html-to-powerpoint",
		"javascript-create-powerpoint",
		"javascript-create-pptx",
		"javascript-generate-pptx",
		"javascript-powerpoint",
		"javascript-powerpoint-charts",
		"javascript-pptx",
		"js-create-powerpoint",
		"js-create-pptx",
		"js-generate-powerpoint",
		"js-powerpoint",
		"js-powerpoint-library",
		"js-powerpoint-pptx",
		"node-powerpoint",
		"officejs-alternative",
		"react-powerpoint",
		"slide-generator",
		"typescript-powerpoint"
	],
	"bugs": {
		"url": "https://github.com/gitbrent/PptxGenJS/issues"
	}
}
