{
	"name": "@shbernal/pptxgenjs",
	"version": "5.0.1",
	"author": {
		"name": "shbernal",
		"url": "https://github.com/shbernal/"
	},
	"description": "Create JavaScript PowerPoint Presentations",
	"homepage": "https://github.com/shbernal/PptxGenJS#readme",
	"license": "MIT",
	"packageManager": "pnpm@11.3.0",
	"type": "module",
	"engines": {
		"node": ">=24"
	},
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"browser": "./dist/browser.js",
			"node": "./dist/node.js",
			"default": "./dist/index.js"
		},
		"./core": {
			"types": "./dist/core.d.ts",
			"default": "./dist/core.js"
		},
		"./inspect": {
			"types": "./dist/inspect.d.ts",
			"default": "./dist/inspect.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"node": "./dist/node.js",
			"default": "./dist/node.js"
		},
		"./browser": {
			"types": "./dist/browser.d.ts",
			"browser": "./dist/browser.js",
			"default": "./dist/browser.js"
		},
		"./standalone": {
			"types": "./dist/standalone.d.ts",
			"browser": "./dist/standalone.js",
			"default": "./dist/standalone.js"
		},
		"./package.json": {
			"default": "./package.json"
		}
	},
	"files": [
		"dist"
	],
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsdown",
		"start": "pnpm run watch",
		"watch": "tsdown --watch",
		"test": "pnpm run build && vitest run test/regression test/schema-validation.test.mjs",
		"test:unit": "pnpm run build && vitest run test/regression",
		"test:schema": "pnpm run build && vitest run test/schema-validation.test.mjs",
		"test:watch": "pnpm run build && vitest --watch test/regression",
		"test:coverage": "pnpm run build && vitest run --coverage test/regression",
		"test:package": "node scripts/package-smoke.mjs",
		"test:demo:node": "node scripts/demo-smoke.mjs node",
		"test:demo:vite": "node scripts/demo-smoke.mjs vite",
		"test:demos": "node scripts/demo-smoke.mjs",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"strict:check": "tsc -p tsconfig.strict.json --noEmit",
		"strict:null:check": "tsc -p tsconfig.strict-null.json --noEmit",
		"lint": "eslint . --no-warn-ignored",
		"lint:fix": "pnpm run lint -- --fix",
		"format": "prettier package.json pnpm-workspace.yaml typedoc.docs.json tsconfig*.json docs/docs.json docs/tsconfig.json docs/.vitepress/config.mts eslint.config.mjs tsdown.config.ts \"scripts/**/*.mjs\" \"test/**/*.mjs\" \"test/**/*.js\" \".github/**/*.yml\" --write",
		"format:check": "prettier package.json pnpm-workspace.yaml typedoc.docs.json tsconfig*.json docs/docs.json docs/tsconfig.json docs/.vitepress/config.mts eslint.config.mjs tsdown.config.ts \"scripts/**/*.mjs\" \"test/**/*.mjs\" \"test/**/*.js\" \".github/**/*.yml\" --check",
		"package:lint": "node scripts/package-lint.mjs",
		"upstream:signals": "node scripts/upstream-signals-ledger.mjs",
		"upstream:signals:list": "node scripts/upstream-signals-ledger.mjs list",
		"upstream:signals:validate": "node scripts/upstream-signals-ledger.mjs validate",
		"upstream:signals:check": "node scripts/upstream-signals-check.mjs",
		"upstream:signals:check:json": "node scripts/upstream-signals-check.mjs --json",
		"test:tools": "vitest run test/upstream-signals-ledger.test.mjs",
		"prepack": "pnpm run build",
		"check-validator": "node tools/ooxml-validator/check-updates.js",
		"pack:check": "pnpm pack --dry-run --json",
		"docs:init": "python3 scripts/docs-init.py",
		"docs:list": "python3 scripts/docs-list.py",
		"docs:new": "python3 scripts/docs-new.py",
		"docs:api": "node scripts/docs-api.mjs",
		"docs:llms": "node scripts/generate-llms-docs.mjs",
		"docs:check": "pnpm run docs:api && python3 scripts/docs-check.py",
		"docs:prepare": "pnpm run docs:api && pnpm run docs:llms",
		"docs:dev": "pnpm run docs:prepare && vitepress dev docs",
		"docs:build": "pnpm run docs:prepare && python3 scripts/docs-check.py && vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"dependencies": {
		"fast-xml-parser": "^5.8.0",
		"jszip": "^3.10.1"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.3",
		"@arethetypeswrong/core": "^0.18.3",
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.9.2",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^10.4.1",
		"prettier": "^3.8.3",
		"publint": "^0.3.21",
		"tsdown": "^0.22.2",
		"tslib": "^2.8.1",
		"typedoc": "^0.28.19",
		"typedoc-plugin-markdown": "^4.12.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vitepress": "^1.6.4",
		"vitest": "^4.1.8",
		"yaml": "^2.9.0"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shbernal/PptxGenJS.git"
	},
	"keywords": [
		"es6-powerpoint",
		"html-to-powerpoint",
		"javascript-create-powerpoint",
		"javascript-create-pptx",
		"javascript-generate-pptx",
		"javascript-powerpoint",
		"javascript-powerpoint-charts",
		"javascript-pptx",
		"js-create-powerpoint",
		"js-create-pptx",
		"js-generate-powerpoint",
		"js-powerpoint",
		"js-powerpoint-library",
		"js-powerpoint-pptx",
		"node-powerpoint",
		"officejs-alternative",
		"react-powerpoint",
		"slide-generator",
		"typescript-powerpoint"
	],
	"bugs": {
		"url": "https://github.com/shbernal/PptxGenJS/issues"
	}
}
