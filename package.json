{
	"name": "pptxgenjs",
	"version": "4.0.1",
	"author": {
		"name": "Brent Ely",
		"url": "https://github.com/gitbrent/"
	},
	"description": "Create JavaScript PowerPoint Presentations",
	"homepage": "https://gitbrent.github.io/PptxGenJS/",
	"license": "MIT",
	"packageManager": "npm@11.14.1",
	"engines": {
		"node": ">=24"
	},
	"exports": {
		"types": "./types/pptxgen.d.ts",
		"import": "./dist/pptxgen.es.js",
		"require": "./dist/pptxgen.cjs.js"
	},
	"main": "dist/pptxgen.cjs.js",
	"module": "dist/pptxgen.es.js",
	"files": [
		"dist",
		"types"
	],
	"types": "types/pptxgen.d.ts",
	"scripts": {
		"build": "node scripts/build.mjs build",
		"build:dist": "node scripts/build.mjs dist",
		"copy:browser": "node scripts/build.mjs copy:browser",
		"copy:node": "node scripts/build.mjs copy:node",
		"copy:vite": "node scripts/build.mjs copy:vite",
		"start": "npm run watch",
		"ship": "node scripts/build.mjs ship",
		"defs": "node scripts/build.mjs copy:vite-types",
		"watch": "rollup -cw",
		"pretest": "npm run build",
		"pretest:unit": "npm run build",
		"pretest:schema": "npm run build",
		"test": "vitest run test/regression.test.mjs && vitest run test/schema-validation.test.mjs",
		"test:unit": "vitest run test/regression.test.mjs",
		"test:schema": "vitest run test/schema-validation.test.mjs",
		"test:watch": "npm run build && vitest --watch test/regression.test.mjs",
		"test:coverage": "npm run build && vitest run --coverage test/regression.test.mjs",
		"test:package": "node scripts/package-smoke.mjs",
		"schema-test": "npm run test:schema",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"types:build": "node scripts/types.mjs",
		"lint": "eslint . --no-warn-ignored",
		"lint:fix": "npm run lint -- --fix",
		"format": "prettier package.json tsconfig*.json eslint.config.mjs rollup.config.mjs \"scripts/**/*.mjs\" \"test/**/*.mjs\" \".github/**/*.yml\" --write",
		"format:check": "prettier package.json tsconfig*.json eslint.config.mjs rollup.config.mjs \"scripts/**/*.mjs\" \"test/**/*.mjs\" \".github/**/*.yml\" --check",
		"prepack": "npm run build:dist && npm run types:build",
		"check-validator": "node tools/ooxml-validator/check-updates.js",
		"pack:check": "npm pack --dry-run --json"
	},
	"browser": {
		"express": false,
		"fs": false,
		"https": false,
		"node:fs": false,
		"node:https": false,
		"os": false,
		"path": false
	},
	"dependencies": {
		"jszip": "^3.10.1"
	},
	"devDependencies": {
		"@eslint/js": "^9.25.1",
		"@rollup/plugin-commonjs": "^28.0.1",
		"@rollup/plugin-node-resolve": "^16.0.1",
		"@rollup/plugin-typescript": "^12.3.0",
		"@stylistic/eslint-plugin": "^4.2.0",
		"@types/node": "^22.8.1",
		"@typescript-eslint/eslint-plugin": "^8.31.0",
		"@typescript-eslint/parser": "^8.31.0",
		"@vitest/coverage-v8": "^4.1.8",
		"eslint": "^9.25.1",
		"express": "^5.1.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"rollup": "^4.24.2",
		"terser": "^5.48.0",
		"tslib": "^2.8.0",
		"typescript": "^5.6.3",
		"typescript-eslint": "^8.31.0",
		"vitest": "^4.1.8"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gitbrent/PptxGenJS.git"
	},
	"keywords": [
		"es6-powerpoint",
		"html-to-powerpoint",
		"javascript-create-powerpoint",
		"javascript-create-pptx",
		"javascript-generate-pptx",
		"javascript-powerpoint",
		"javascript-powerpoint-charts",
		"javascript-pptx",
		"js-create-powerpoint",
		"js-create-pptx",
		"js-generate-powerpoint",
		"js-powerpoint",
		"js-powerpoint-library",
		"js-powerpoint-pptx",
		"node-powerpoint",
		"officejs-alternative",
		"react-powerpoint",
		"slide-generator",
		"typescript-powerpoint"
	],
	"bugs": {
		"url": "https://github.com/gitbrent/PptxGenJS/issues"
	}
}
