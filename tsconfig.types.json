{
	"$schema": "https://json.schemastore.org/tsconfig",
	"display": "PptxGenJS public declarations",
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"declaration": true,
		"declarationDir": "./types",
		"emitDeclarationOnly": true,
		"noEmit": false,
		"rootDir": "./src",
		"sourceMap": false
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/bld/**"]
}
